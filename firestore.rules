rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── User documents ───
    // Users can read/write their own document; admins can read/update any user
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // Users can update their own doc; admins can update any user
      // But nobody can write the 'role' field from the client (role changes require Cloud Functions)
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // ─── User sub-collections ───

      // Progress data (streak, lessons, weekly entries)
      match /progress/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);

        match /entries/{entryId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId);
        }

        // Daily activity logs (progress/daily/{YYYY-MM-DD})
        match /{dateId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId);
        }
      }

      // Lesson progress & attempts
      match /lessons/{lessonId} {
        allow read, write: if isOwner(userId);

        match /attempts/{attemptId} {
          allow read, write: if isOwner(userId);
        }

        match /conversationTurns/{turnId} {
          allow read, write: if isOwner(userId);
        }

        match /vocabPairs/{pairId} {
          allow read: if isOwner(userId);
        }
      }

      // Pronunciation attempts
      match /pronunciation_attempts/{attemptId} {
        allow read, write: if isOwner(userId);
      }

      // Notifications
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }

      // Login devices
      match /devices/{deviceId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── Global lessons collection ───
    // All authenticated users can read; only admins can write
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /vocabPairs/{pairId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // ─── Pronunciation sentences ───
    match /pronunciation_sentences/{sentenceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Announcements ───
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Admin Analytics ───
    // Only admins can read/write the aggregated dashboard data
    match /admin_analytics/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();

      // Daily snapshots sub-collection
      match /{snapshotId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }
    }

    // ─── OTP codes for password reset (used by Cloud Functions, no direct client access) ───
    match /password_reset_otps/{docId} {
      allow read, write: if false;
    }

    // ─── OTP codes for signup verification (used by Cloud Functions, no direct client access) ───
    match /signup_verification_otps/{docId} {
      allow read, write: if false;
    }

    // ─── Legacy OTP codes (used by Cloud Functions, no direct client access) ───
    match /otp_codes/{docId} {
      allow read, write: if false;
    }

    // ─── 2FA codes (used by Cloud Functions, no direct client access) ───
    match /two_factor_codes/{docId} {
      allow read, write: if false;
    }
  }
}
